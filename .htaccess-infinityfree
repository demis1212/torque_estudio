# Configuración .htaccess para InfinityFree
# Colocar este archivo en /htdocs/ (raíz del sitio en InfinityFree)

# Activar motor de reescritura
RewriteEngine On

# Redirigir todo a index.php excepto archivos y directorios existentes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# Proteger archivos sensibles
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "\.(sql|log|ini|md|env|git|gitignore|gitattributes|sh|bash)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Deshabilitar listado de directorios
Options -Indexes

# Configurar charset
AddDefaultCharset UTF-8

# Configuración PHP (InfinityFree tiene límites estrictos)
# Descomenta las líneas si están permitidas en tu plan
# php_value upload_max_filesize 10M
# php_value post_max_size 10M
# php_value max_execution_time 60
# php_value max_input_time 60
# php_value memory_limit 128M

# Compresión gzip (si está disponible)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript
</IfModule>

# Caché del navegador (optimización)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
